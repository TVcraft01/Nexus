{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nexus Skill Manifest",
  "description": "Standard manifest every Nexus skill must include",
  "type": "object",
  "required": ["id","name","version","description","author","platform","permissions","entry"],
  "properties": {
    "id":          { "type": "string",  "description": "Unique skill ID e.g. media-spotify" },
    "name":        { "type": "string",  "description": "Human readable name" },
    "version":     { "type": "string",  "description": "Semver e.g. 1.0.0" },
    "description": { "type": "string",  "description": "What this skill does" },
    "author":      { "type": "string",  "description": "GitHub username or anonymous" },
    "platform": {
      "type": "array",
      "items": { "enum": ["linux","windows","macos","android","ios","any"] },
      "description": "Supported platforms"
    },
    "min_ram_mb":  { "type": "number",  "description": "Minimum RAM in MB required" },
    "permissions": {
      "type": "array",
      "items": { "enum": ["internet","microphone","camera","filesystem","bluetooth","network_local","execute_shell","notifications"] },
      "description": "Permissions shown to user before install"
    },
    "entry":       { "type": "string",  "description": "Entry point file e.g. main.py" },
    "triggers":    { "type": "array",   "items": { "type": "string" }, "description": "Voice/text phrases that activate this skill" },
    "sandboxed":   { "type": "boolean", "description": "Whether skill runs in isolated environment" },
    "auto_remove_days": { "type": "number", "description": "Remove after N days of no use (0 = never)" },
    "community_verified": { "type": "boolean", "description": "Passed community sandbox check" }
  }
}
